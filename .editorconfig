root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 4

[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{html,css,scss}]
indent_size = 2

[*.mongo]
indent_size = 4

[package-lock.json]
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = tab

[Makefile]
indent_style = tab
